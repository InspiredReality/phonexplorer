# Copy to .env and fill in values — never commit .env to git

# CORS: comma-separated list of allowed frontend origins
ALLOWED_ORIGINS_RAW=http://localhost:3000,https://your-app.vercel.app

# PostgreSQL — Railway injects this automatically in production.
# For local dev, set up a local Postgres DB or use a Railway dev environment.
# Both postgres:// and postgresql:// are accepted; asyncpg driver is applied automatically.
DATABASE_URL_RAW=postgresql://user:password@localhost:5432/phonexplorer

# Monday.com
# Get from: monday.com → Avatar → Administration → API → Personal API token
MONDAY_API_TOKEN=

# Add more external API keys here as you integrate them
# EXAMPLE_API_KEY=
# EXAMPLE_API_BASE_URL=https://api.example.com
