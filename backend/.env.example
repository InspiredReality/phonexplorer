# Copy to .env and fill in values — never commit .env to git

# CORS: comma-separated list of allowed frontend origins
ALLOWED_ORIGINS_RAW=http://localhost:3000,https://your-app.vercel.app

# Monday.com
# Get from: monday.com → Avatar → Administration → API → Personal API token
MONDAY_API_TOKEN=

# Add more external API keys here as you integrate them
# EXAMPLE_API_KEY=
# EXAMPLE_API_BASE_URL=https://api.example.com
